from google.colab import auth
auth.authenticate_user()


# =====================================================
# IMPORTS
# =====================================================

from pyspark.sql import SparkSession
from pyspark.sql.window import Window
from pyspark.storagelevel import StorageLevel

from pyspark.sql.functions import (
    col,
    trim,
    when,
    upper,
    concat_ws,
    broadcast,
    row_number,
    monotonically_increasing_id
)


# =====================================================
# CONFIG
# =====================================================

PROJECT_ID = "project-1928c187-e191-4e50-bee"

TEMP_BUCKET = "spalika_sales_data"


# =====================================================
# SPARK SESSION
# =====================================================

spark = (
    SparkSession.builder
    .appName("GoldDimProducts")

    .config(
        "spark.jars.packages",
        "com.google.cloud.spark:spark-3.5-bigquery:0.42.1"
    )

    .config(
        "temporaryGcsBucket",
        TEMP_BUCKET
    )

    .config(
        "parentProject",
        PROJECT_ID
    )

    # PERFORMANCE
    .config("spark.sql.shuffle.partitions", "8")
    .config("spark.default.parallelism", "8")

    .getOrCreate()
)

print("Spark Version:", spark.version)


# =====================================================
# READ TABLES FROM BIGQUERY
# =====================================================

crm_products_df = (
    spark.read.format("bigquery")
    .load(
        "project-1928c187-e191-4e50-bee:silver_sales_ds.crm_products"
    )
)

erp_product_category_df = (
    spark.read.format("bigquery")
    .load(
        "project-1928c187-e191-4e50-bee:silver_sales_ds.erp_product_category"
    )
)


# =====================================================
# REMOVE DUPLICATES
# =====================================================

pc_clean = (
    erp_product_category_df
    .dropDuplicates(["ID"])
)


# =====================================================
# CREATE ALIASES
# =====================================================

prd = crm_products_df.alias("prd")
pc = pc_clean.alias("pc")


# =====================================================
# BROADCAST JOIN
# =====================================================

product_dim_df = (
    prd.join(
        broadcast(pc),
        col("prd.cid") == col("pc.ID"),
        "left"
    )

    .select(
        col("prd.prd_id"),

        col("prd.prd_key"),

        col("prd.prd_nm")
        .alias("product_name"),

        col("prd.prd_cost")
        .alias("product_cost"),

        col("prd.prd_line")
        .alias("product_line"),

        col("prd.prd_start_dt"),

        col("prd.prd_end_dt"),

        col("prd.cid"),

        col("pc.CAT")
        .alias("product_cat"),

        col("pc.SUBCAT")
        .alias("product_sub_cat"),

        col("pc.MAINTENANCE")
    )
)


# =====================================================
# ADD SURROGATE KEY
# =====================================================

product_dim_df = product_dim_df.withColumn(
    "product_sk",
    monotonically_increasing_id()
)


# =====================================================
# COLUMN ORDER
# =====================================================

product_dim_df = product_dim_df.select(
    "product_sk",
    "prd_id",
    "prd_key",
    "product_name",
    "product_cost",
    "product_line",
    "product_cat",
    "product_sub_cat",
    "MAINTENANCE",
    "prd_start_dt",
    "prd_end_dt"
)


# =====================================================
# CACHE FOR PERFORMANCE
# =====================================================

product_dim_df.persist(StorageLevel.MEMORY_AND_DISK)


# =====================================================
# REPARTITION FOR PARALLEL WRITE
# =====================================================

product_dim_df = product_dim_df.repartition(4)


# =====================================================
# SHOW DATA
# =====================================================

product_dim_df.show(10, truncate=False)


# =====================================================
# WRITE TO CSV
# =====================================================

output_path = "/content/gold_dim_products_csv"

(
    product_dim_df.write
    .mode("overwrite")
    .option("header", True)
    .option("compression", "snappy")
    .csv(output_path)
)

print("CSV written successfully!")


# =====================================================
# VERIFY OUTPUT
# =====================================================

print("Total Rows:", product_dim_df.count())


