import argparse

from pyspark.sql import DataFrame, SparkSession
from pyspark.sql.window import Window

from pyspark.sql.functions import (
    col,
    trim,
    when,
    regexp_replace,
    row_number,
    current_timestamp,
    max as spark_max,
    lit,
)


REQUIRED_COLUMNS = [
    "CID",
    "CNTRY",
]


COUNTRY_MAPPING = {
    "US": "United States",
    "USA": "United States",
    "DE": "Germany",
    "UK": "United Kingdom",
}


def parse_args():

    parser = argparse.ArgumentParser(
        description="Incremental ERP Customer Location Silver Pipeline"
    )

    parser.add_argument(
        "--project",
        required=True,
        help="Google Cloud project id",
    )

    parser.add_argument(
        "--source-dataset",
        default="bronze_sales_ds",
        help="Bronze dataset",
    )

    parser.add_argument(
        "--source-table",
        default="erp_customer_loc_raw",
        help="Bronze source table",
    )

    parser.add_argument(
        "--target-dataset",
        default="silver_sales_ds",
        help="Silver dataset",
    )

    parser.add_argument(
        "--target-table",
        default="erp_customer_loc",
        help="Silver target table",
    )

    parser.add_argument(
        "--temporary-gcs-bucket",
        required=True,
        help="Temporary GCS bucket",
    )

    parser.add_argument(
        "--materialization-dataset",
        default="spark_temp",
        help="Materialization dataset",
    )

    parser.add_argument(
        "--write-mode",
        default="append",
        choices=["overwrite", "append"],
        help="Write mode",
    )

    return parser.parse_args()


def build_spark(
    app_name: str,
    project: str,
    materialization_dataset: str,
) -> SparkSession:

    return (
        SparkSession.builder
        .appName(app_name)
        .config("viewsEnabled", "true")
        .config("parentProject", project)
        .config(
            "materializationDataset",
            materialization_dataset,
        )
        .getOrCreate()
    )


def validate_schema(df: DataFrame):

    missing_columns = [
        c for c in REQUIRED_COLUMNS
        if c not in df.columns
    ]

    if missing_columns:

        raise ValueError(
            f"Missing required columns: {missing_columns}"
        )


# =====================================================
# GET LAST WATERMARK
# =====================================================

def get_last_watermark(
    spark,
    project,
    dataset,
    table,
):

    try:

        silver_df = (
            spark.read.format("bigquery")
            .option(
                "table",
                f"{project}.{dataset}.{table}"
            )
            .load()
        )

        watermark = (
            silver_df
            .select(
                spark_max("ingestion_dt")
                .alias("max_dt")
            )
            .collect()[0]["max_dt"]
        )

        return watermark

    except:

        return None


# =====================================================
# FILTER INCREMENTAL RECORDS
# =====================================================

def filter_incremental(
    df: DataFrame,
    last_watermark,
):

    if last_watermark is None:
        return df

    return df.filter(
        col("ingestion_dt") > lit(last_watermark)
    )


# =====================================================
# CLEAN COUNTRY
# =====================================================

def clean_country(df: DataFrame) -> DataFrame:

    cleaned_df = df.withColumn(
        "CNTRY",
        when(
            trim(col("CNTRY")) == "",
            None
        ).otherwise(
            trim(col("CNTRY"))
        )
    )

    cleaned_df = cleaned_df.replace(
        COUNTRY_MAPPING,
        subset=["CNTRY"]
    )

    return cleaned_df


# =====================================================
# CLEAN CUSTOMER ID
# =====================================================

def clean_customer_id(df: DataFrame) -> DataFrame:

    return (
        df.withColumn(
            "CID",
            regexp_replace(
                col("CID"),
                "-",
                ""
            )
        )
        .filter(col("CID").isNotNull())
    )


# =====================================================
# DEDUPLICATE RECORDS
# =====================================================

def deduplicate_records(
    df: DataFrame
) -> DataFrame:

    window_spec = (
        Window
        .partitionBy("CID")
        .orderBy(col("CID"))
    )

    return (
        df.withColumn(
            "rn",
            row_number().over(window_spec)
        )
        .filter(col("rn") == 1)
        .drop("rn")
    )


# =====================================================
# MAIN CLEANING PIPELINE
# =====================================================

def clean_customer_location(
    df: DataFrame
) -> DataFrame:

    cleaned_df = (
        df.transform(clean_country)
        .transform(clean_customer_id)
    )

    dedup_df = deduplicate_records(
        cleaned_df
    )

    final_df = dedup_df.withColumn(
        "ingestion_dt",
        current_timestamp()
    )

    return final_df


# =====================================================
# WRITE TO BIGQUERY
# =====================================================

def write_bq(
    df: DataFrame,
    table: str,
    temporary_gcs_bucket: str,
    mode: str,
):

    (
        df.write
        .format("bigquery")
        .option("table", table)
        .option(
            "temporaryGcsBucket",
            temporary_gcs_bucket
        )
        .mode(mode)
        .save()
    )


def main():

    args = parse_args()

    source_table = (
        f"{args.project}."
        f"{args.source_dataset}."
        f"{args.source_table}"
    )

    target_table = (
        f"{args.project}."
        f"{args.target_dataset}."
        f"{args.target_table}"
    )

    spark = build_spark(
        app_name="erp-customer-location-silver",
        project=args.project,
        materialization_dataset=args.materialization_dataset,
    )

    # =====================================================
    # READ BRONZE TABLE
    # =====================================================

    raw_df = (
        spark.read.format("bigquery")
        .option("table", source_table)
        .load()
    )

    validate_schema(raw_df)

    source_count = raw_df.count()

    print(f"Source Records: {source_count}")

    # =====================================================
    # GET WATERMARK
    # =====================================================

    last_watermark = get_last_watermark(
        spark=spark,
        project=args.project,
        dataset=args.target_dataset,
        table=args.target_table,
    )

    print(f"Last Watermark: {last_watermark}")

    # =====================================================
    # FILTER INCREMENTAL DATA
    # =====================================================

    incremental_df = filter_incremental(
        raw_df,
        last_watermark,
    )

    incremental_count = incremental_df.count()

    print(
        f"Incremental Records: "
        f"{incremental_count}"
    )

    if incremental_count == 0:

        print("No new records found")

        spark.stop()

        return

    # =====================================================
    # CLEAN DATA
    # =====================================================

    clean_df = clean_customer_location(
        incremental_df
    )

    target_count = clean_df.count()

    print(
        f"Clean Records: "
        f"{target_count}"
    )

    clean_df.select("CNTRY").distinct().show()

    # =====================================================
    # WRITE TO SILVER
    # =====================================================

    write_bq(
        clean_df,
        table=target_table,
        temporary_gcs_bucket=args.temporary_gcs_bucket,
        mode=args.write_mode,
    )

    print(
        f"Wrote {target_count} rows "
        f"to {target_table}"
    )

    spark.stop()


if __name__ == "__main__":
    main()