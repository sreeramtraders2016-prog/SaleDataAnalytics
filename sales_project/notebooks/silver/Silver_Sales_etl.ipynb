auth.authenticate_user()


# =====================================================
# IMPORTS
# =====================================================

from pyspark.sql import SparkSession
from google.cloud import bigquery
from pyspark.sql.window import Window
from pyspark.sql.functions import col, count
from pyspark.sql.functions import row_number, rank, dense_rank, col
from pyspark.sql.functions import (
    trim,
    when,
    col,
    upper,
    to_date,
    current_timestamp,
    sum
)


# =====================================================
# CONFIG
# =====================================================

PROJECT_ID = "project-1928c187-e191-4e50-bee"

TEMP_BUCKET = "spalika_sales_data"


# =====================================================
# SPARK SESSION
# =====================================================

spark = (
    SparkSession.builder
    .appName("BigQueryIntegration")

    .config(
        "spark.jars.packages",
        ",".join([
            "com.google.cloud.spark:spark-3.5-bigquery:0.42.1",
            "com.google.cloud.bigdataoss:gcs-connector:hadoop3-2.2.21"
        ])
    )

    # IMPORTANT
    .config(
        "spark.hadoop.google.cloud.auth.service.account.enable",
        "false"
    )

    .config(
        "spark.hadoop.fs.gs.impl",
        "com.google.cloud.hadoop.fs.gcs.GoogleHadoopFileSystem"
    )

    .config(
        "spark.hadoop.fs.AbstractFileSystem.gs.impl",
        "com.google.cloud.hadoop.fs.gcs.GoogleHadoopFS"
    )

    .config(
        "temporaryGcsBucket",
        TEMP_BUCKET
    )

    .config(
        "parentProject",
        PROJECT_ID
    )

    .getOrCreate()
)

print("Spark Version:", spark.version)


# =====================================================
# READ BRONZE TABLE
# =====================================================

df = (
    spark.read.format("bigquery")
    .load(
        "project-1928c187-e191-4e50-bee:bronze_sales_ds.crm_sales_raw"
    )
)
#df.show()
#print(df.count())


window_spec = Window.partitionBy("sls_ord_num") \
                    .orderBy(col("sls_order_dt").desc())

df_ranked = df.withColumn(
    "row_num",
    row_number().over(window_spec)
)
df_ranked  = df_ranked.filter(col("row_num") == 1)
df_ranked  = df_ranked .withColumn("sls_ord_num",trim(col("sls_ord_num"))
).withColumn("sls_prd_key",trim(col("sls_prd_key")))
df_ranked   =df_ranked.withColumn("sls_quantity",col("sls_quantity").cast("int")
)
from pyspark.sql.functions import col

df_ranked  = df_ranked.withColumn(
    "sls_price",
    col("sls_price").cast("float")
).withColumn(
    "sls_sales",
    col("sls_sales").cast("float")
)


date_cols = ["sls_order_dt", "sls_ship_dt"]

for c in date_cols:
    df_ranked  = df_ranked.withColumn(
        c,
        to_date(col(c).cast("string"), "yyyyMMdd")
    )
df_ranked  = df_ranked.withColumn("sls_due_dt",to_date(col("sls_due_dt").cast("string"),"yyyyMMdd")
    )
df_ranked  = df_ranked.withColumn(
    "sls_sales_calc",
    col("sls_quantity") * col("sls_price")
)
df_ranked   = df_ranked.withColumn("ingestion_dt",current_timestamp())
df_ranked= df_ranked.drop("row_num")

invalid_df=df_ranked.withColumn(
    "sales_mismatch",
    col("sls_sales") != col("sls_sales_calc")
).filter("sales_mismatch = true")
valid_df=df_ranked.withColumn(
    "sales_mismatch",
    col("sls_sales") == col("sls_sales_calc")
).filter("sales_mismatch = false")

#
#latest_orders.show()
#df_ranked.show()
#sf.show
#print(latest_orders.count())
#valid_df.show()
#invalid_df.show()


# Convert Spark DataFrame to Pandas
pandas_df = df_ranked.toPandas()
df_ranked.printSchema()

# Create BigQuery client
client = bigquery.Client(project=PROJECT_ID)

# Target table
table_id = (
    "project-1928c187-e191-4e50-bee"
    ".silver_sales_ds.crm_sales"
)

# Load job config
job_config = bigquery.LoadJobConfig(
    write_disposition="WRITE_APPEND"
)

# Load to BigQuery
job = client.load_table_from_dataframe(pandas_df,table_id,job_config=job_config )

# Wait for completion
job.result()

print("Silver table loaded successfully!")

