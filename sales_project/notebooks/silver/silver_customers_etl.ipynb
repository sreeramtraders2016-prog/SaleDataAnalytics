import argparse

from pyspark.sql import DataFrame, SparkSession
from pyspark.sql.functions import (
    col,
    row_number,
    trim,
    upper,
    when,
    lit,
    current_timestamp,
    max as spark_max,
)
from pyspark.sql.window import Window


REQUIRED_COLUMNS = [
    "cst_id",
    "cst_key",
    "cst_firstname",
    "cst_lastname",
    "cst_marital_status",
    "cst_gndr",
    "cst_create_date",
]

TRIM_COLUMNS = [
    "cst_key",
    "cst_firstname",
    "cst_lastname",
    "cst_marital_status",
    "cst_gndr",
]


def parse_args():
    parser = argparse.ArgumentParser(
        description="Incremental Silver Customer Pipeline"
    )

    parser.add_argument(
        "--project",
        required=True,
        help="Google Cloud project id",
    )

    parser.add_argument(
        "--source-dataset",
        default="bronze_sales_ds",
        help="Bronze dataset",
    )

    parser.add_argument(
        "--source-table",
        default="crm_customers_raw",
        help="Bronze source table",
    )

    parser.add_argument(
        "--target-dataset",
        default="silver_sales_ds",
        help="Silver dataset",
    )

    parser.add_argument(
        "--target-table",
        default="crm_customers",
        help="Silver target table",
    )

    parser.add_argument(
        "--temporary-gcs-bucket",
        required=True,
        help="Temporary GCS bucket",
    )

    parser.add_argument(
        "--materialization-dataset",
        default="spark_temp",
        help="Materialization dataset",
    )

    parser.add_argument(
        "--write-mode",
        default="append",
        choices=["overwrite", "append"],
        help="Write mode",
    )

    return parser.parse_args()


def build_spark(
    app_name: str,
    project: str,
    materialization_dataset: str,
) -> SparkSession:

    return (
        SparkSession.builder
        .appName(app_name)
        .config("viewsEnabled", "true")
        .config("parentProject", project)
        .config("materializationDataset", materialization_dataset)
        .getOrCreate()
    )


def validate_schema(df: DataFrame):

    missing_columns = [
        c for c in REQUIRED_COLUMNS
        if c not in df.columns
    ]

    if missing_columns:

        raise ValueError(
            f"Missing required columns: {missing_columns}"
        )


def apply_trims(df: DataFrame) -> DataFrame:

    trimmed_df = df

    for column_name in TRIM_COLUMNS:

        trimmed_df = trimmed_df.withColumn(
            column_name,
            trim(col(column_name))
        )

    return trimmed_df


def standardize_gender(column_name: str):

    normalized = upper(trim(col(column_name)))

    return (
        when(
            normalized.isin("M", "MALE"),
            "Male"
        )
        .when(
            normalized.isin("F", "FEMALE"),
            "Female"
        )
        .otherwise("Unknown")
    )


def standardize_marital_status(column_name: str):

    normalized = upper(trim(col(column_name)))

    return (
        when(
            normalized.isin("M", "MARRIED"),
            "Married"
        )
        .when(
            normalized.isin("S", "SINGLE"),
            "Single"
        )
        .otherwise("Unknown")
    )


# =====================================================
# GET LAST WATERMARK
# =====================================================

def get_last_watermark(
    spark,
    project,
    dataset,
    table,
):

    try:

        silver_df = (
            spark.read.format("bigquery")
            .option(
                "table",
                f"{project}.{dataset}.{table}"
            )
            .load()
        )

        watermark = (
            silver_df
            .select(
                spark_max("cst_create_date")
                .alias("max_date")
            )
            .collect()[0]["max_date"]
        )

        return watermark

    except:

        return None


# =====================================================
# FILTER INCREMENTAL RECORDS
# =====================================================

def filter_incremental(
    df: DataFrame,
    last_watermark,
):

    if last_watermark is None:
        return df

    return df.filter(
        col("cst_create_date") > lit(last_watermark)
    )


def clean_customers(df: DataFrame) -> DataFrame:

    trimmed_df = (
        apply_trims(df)
        .withColumn(
            "cst_id_text",
            trim(col("cst_id").cast("string"))
        )
    )

    valid_customers_df = (

        trimmed_df

        .filter(
            col("cst_id_text").isNotNull()
            & (col("cst_id_text") != "")
            & col("cst_id_text").rlike("^[0-9]+$")
        )

        .withColumn(
            "cst_id",
            col("cst_id_text").cast("int")
        )

        .drop("cst_id_text")

        .withColumn(
            "cst_create_date",
            col("cst_create_date").cast("date")
        )

        .withColumn(
            "cst_gndr",
            standardize_gender("cst_gndr")
        )

        .withColumn(
            "cst_marital_status",
            standardize_marital_status(
                "cst_marital_status"
            )
        )
    )

    latest_customer_window = (
        Window
        .partitionBy("cst_id")
        .orderBy(
            col("cst_create_date").desc_nulls_last(),
            col("cst_key").asc_nulls_last(),
        )
    )

    final_df = (

        valid_customers_df

        .withColumn(
            "rn",
            row_number().over(
                latest_customer_window
            )
        )

        .filter(col("rn") == 1)

        .drop("rn")

        .withColumn(
            "ingestion_timestamp",
            current_timestamp()
        )
    )

    return final_df


def write_bq(
    df: DataFrame,
    table: str,
    temporary_gcs_bucket: str,
    mode: str,
):

    (
        df.write
        .format("bigquery")
        .option("table", table)
        .option(
            "temporaryGcsBucket",
            temporary_gcs_bucket
        )
        .mode(mode)
        .save()
    )


def main():

    args = parse_args()

    source_table = (
        f"{args.project}."
        f"{args.source_dataset}."
        f"{args.source_table}"
    )

    target_table = (
        f"{args.project}."
        f"{args.target_dataset}."
        f"{args.target_table}"
    )

    spark = build_spark(
        app_name="crm-customers-silver-incremental",
        project=args.project,
        materialization_dataset=args.materialization_dataset,
    )

    # =====================================================
    # READ BRONZE DATA
    # =====================================================

    raw_df = (
        spark.read
        .format("bigquery")
        .option("table", source_table)
        .load()
    )

    validate_schema(raw_df)

    # =====================================================
    # GET WATERMARK
    # =====================================================

    last_watermark = get_last_watermark(
        spark=spark,
        project=args.project,
        dataset=args.target_dataset,
        table=args.target_table,
    )

    print(f"Last Watermark: {last_watermark}")

    # =====================================================
    # FILTER ONLY NEW RECORDS
    # =====================================================

    incremental_df = filter_incremental(
        raw_df,
        last_watermark,
    )

    incremental_count = incremental_df.count()

    print(f"Incremental Records: {incremental_count}")

    if incremental_count == 0:

        print("No new customer records found")

        spark.stop()

        return

    # =====================================================
    # CLEAN DATA
    # =====================================================

    clean_df = clean_customers(
        incremental_df
    )

    source_count = raw_df.count()

    target_count = clean_df.count()

    # =====================================================
    # WRITE TO SILVER
    # =====================================================

    write_bq(
        clean_df,
        table=target_table,
        temporary_gcs_bucket=args.temporary_gcs_bucket,
        mode=args.write_mode,
    )

    print(
        f"Read {source_count} rows "
        f"from {source_table}"
    )

    print(
        f"Wrote {target_count} rows "
        f"to {target_table}"
    )

    spark.stop()


if __name__ == "__main__":
    main()