auth.authenticate_user()


# =====================================================
# IMPORTS
# =====================================================

from pyspark.sql import SparkSession
from google.cloud import bigquery
from pyspark.sql.functions import (
    trim,
    when,
    col,
    upper,
    to_date,
    sum
)


# =====================================================
# CONFIG
# =====================================================

PROJECT_ID = "project-1928c187-e191-4e50-bee"

TEMP_BUCKET = "spalika_sales_data"


# =====================================================
# SPARK SESSION
# =====================================================

spark = (
    SparkSession.builder
    .appName("BigQueryIntegration")

    .config(
        "spark.jars.packages",
        ",".join([
            "com.google.cloud.spark:spark-3.5-bigquery:0.42.1",
            "com.google.cloud.bigdataoss:gcs-connector:hadoop3-2.2.21"
        ])
    )

    # IMPORTANT
    .config(
        "spark.hadoop.google.cloud.auth.service.account.enable",
        "false"
    )

    .config(
        "spark.hadoop.fs.gs.impl",
        "com.google.cloud.hadoop.fs.gcs.GoogleHadoopFileSystem"
    )

    .config(
        "spark.hadoop.fs.AbstractFileSystem.gs.impl",
        "com.google.cloud.hadoop.fs.gcs.GoogleHadoopFS"
    )

    .config(
        "temporaryGcsBucket",
        TEMP_BUCKET
    )

    .config(
        "parentProject",
        PROJECT_ID
    )

    .getOrCreate()
)

print("Spark Version:", spark.version)


# =====================================================
# READ BRONZE TABLE
# =====================================================

df = (
    spark.read.format("bigquery")
    .load(
        "project-1928c187-e191-4e50-bee:bronze_sales_ds.crm_customers_raw"
    )
)


# =====================================================
# CLEANING
# =====================================================

clean_df = df.na.drop(subset=["cst_id"])

clean_df = clean_df.dropDuplicates(["cst_id"])
clean_df = clean_df.withColumn("cst_id",col("cst_id").cast("int"))
#clean_df = clean_df.withColumnRenamed("cst_id","customer_id")


# =====================================================
# TRIM COLUMNS
# =====================================================

trim_columns = [
    "cst_key",
    "cst_firstname",
    "cst_lastname",
    "cst_marital_status",
    "cst_gndr"
]

for c in trim_columns:
    clean_df = clean_df.withColumn(
        c,
        trim(col(c))
    )


# =====================================================
# DATE CONVERSION
# =====================================================

clean_df = clean_df.withColumn(
    "cst_create_date",
    to_date("cst_create_date", "yyyy-MM-dd")
)


# =====================================================
# GENDER STANDARDIZATION
# =====================================================

clean_df = clean_df.withColumn(
    "cst_gndr",
    when(
        upper(col("cst_gndr")) == "M",
        "Male"
    )
    .when(
        upper(col("cst_gndr")) == "F",
        "Female"
    )
    .otherwise("Unknown")
)


# =====================================================
# MARITAL STATUS STANDARDIZATION
# =====================================================

clean_df = clean_df.withColumn(
    "cst_marital_status",
    when(
        upper(col("cst_marital_status")) == "M",
        "Married"
    )
    .when(
        upper(col("cst_marital_status")) == "S",
        "Single"
    )
    .otherwise("Unknown")
)


# =====================================================
# SHOW DATA
# =====================================================

clean_df.show(5)


# =====================================================
# NULL CHECK
# =====================================================

clean_df.select([
    sum(col(c).isNull().cast("int")).alias(c)
    for c in clean_df.columns
]).show()


# Convert Spark DataFrame to Pandas
pandas_df = clean_df.toPandas()

# Create BigQuery client
client = bigquery.Client(project=PROJECT_ID)

# Target table
table_id = (
    "project-1928c187-e191-4e50-bee"
    ".silver_sales_ds.crm_customers"
)

# Load job config
job_config = bigquery.LoadJobConfig(
    write_disposition="WRITE_APPEND"
)

# Load to BigQuery
job = client.load_table_from_dataframe(pandas_df,table_id,job_config=job_config )

# Wait for completion
#job.result()

print("Silver table loaded successfully!")

# =====================================================
# WRITE TO BIGQUERY SILVER
# =====================================================
bucket = "spalika_sales_data"
spark.conf.set('temporaryGcsBucket', bucket)

