from google.colab import auth
auth.authenticate_user()


# =====================================================
# IMPORTS
# =====================================================

from pyspark.sql import SparkSession
from google.cloud import bigquery
from pyspark.sql.functions import (
    trim,
    when,
    col,
    upper,
    to_date,
    current_date,
    current_timestamp,
    sum
)


# =====================================================
# CONFIG
# =====================================================

PROJECT_ID = "project-1928c187-e191-4e50-bee"

TEMP_BUCKET = "spalika_sales_data"


# =====================================================
# SPARK SESSION
# =====================================================

spark = (
    SparkSession.builder
    .appName("BigQueryIntegration")

    .config(
        "spark.jars.packages",
        ",".join([
            "com.google.cloud.spark:spark-3.5-bigquery:0.42.1",
            "com.google.cloud.bigdataoss:gcs-connector:hadoop3-2.2.21"
        ])
    )

    # IMPORTANT
    .config(
        "spark.hadoop.google.cloud.auth.service.account.enable",
        "false"
    )

    .config(
        "spark.hadoop.fs.gs.impl",
        "com.google.cloud.hadoop.fs.gcs.GoogleHadoopFileSystem"
    )

    .config(
        "spark.hadoop.fs.AbstractFileSystem.gs.impl",
        "com.google.cloud.hadoop.fs.gcs.GoogleHadoopFS"
    )

    .config(
        "temporaryGcsBucket",
        TEMP_BUCKET
    )

    .config(
        "parentProject",
        PROJECT_ID
    )

    .getOrCreate()
)

print("Spark Version:", spark.version)


# =====================================================
# READ BRONZE TABLE
# =====================================================

df = (
    spark.read.format("bigquery")
    .load(
        "project-1928c187-e191-4e50-bee:bronze_sales_ds.crm_products_raw"
    )
)


clean_df = df.na.drop(
    subset=["prd_id", "prd_key"]
)

# Trim columns
trim_columns = [
    "prd_key",
    "prd_nm",
    "prd_line"
]

for c in trim_columns:
    clean_df = clean_df.withColumn(
        c,
        trim(col(c))
    )

# Product ID
clean_df = clean_df.withColumn(
    "prd_id",
    col("prd_id").cast("int")
)

# Product Cost
clean_df = clean_df.withColumn(
    "prd_cost",
    col("prd_cost").cast("float")
)

clean_df = clean_df.filter(
    col("prd_cost").isNotNull()
)

clean_df = clean_df.filter(
    col("prd_cost") >= 0
)

# Product Line
clean_df = clean_df.withColumn(
    "prd_line",
    when(
        upper(trim(col("prd_line"))) == "M",
        "Mountain"
    )
    .when(
        upper(trim(col("prd_line"))) == "R",
        "Road"
    )
    .when(
        upper(trim(col("prd_line"))) == "S",
        "Standard"
    )
    .when(
        upper(trim(col("prd_line"))) == "T",
        "Touring"
    )
    .otherwise("Unknown")
)

# Dates
clean_df = clean_df.withColumn(
    "prd_start_dt",
    to_date(col("prd_start_dt"), "yyyy-MM-dd")
)

clean_df = clean_df.withColumn(
    "prd_end_dt",
    to_date(col("prd_end_dt"), "yyyy-MM-dd")
)

# Date validations
clean_df = clean_df.filter(
    col("prd_start_dt").isNotNull()
)

clean_df = clean_df.filter(
    (
        col("prd_end_dt").isNull()
    )
    |
    (
        col("prd_start_dt") <= col("prd_end_dt")
    )
)
clean_df = clean_df.withColumn("ingestion_dt",current_timestamp())
#clean_df.show(200)
#clean_df.select("prd_line").distinct().show()

# Convert Spark DataFrame to Pandas
pandas_df = clean_df.toPandas()

# Create BigQuery client
client = bigquery.Client(project=PROJECT_ID)

# Target table
table_id = (
    "project-1928c187-e191-4e50-bee"
    ".silver_sales_ds.crm_products"
)

# Load job config
job_config = bigquery.LoadJobConfig(
    write_disposition="WRITE_APPEND"
)

# Load to BigQuery
job = client.load_table_from_dataframe(pandas_df,table_id,job_config=job_config )

# Wait for completion
job.result()

print("Silver table loaded successfully!")

