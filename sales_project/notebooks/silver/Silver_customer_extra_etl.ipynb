# =====================================================
# AUTHENTICATE
# =====================================================

from google.colab import auth
auth.authenticate_user()


# =====================================================
# IMPORTS
# =====================================================

from pyspark.sql import SparkSession
from google.cloud import bigquery
from pyspark.sql.window import Window
from pyspark.sql.functions import col, count
from pyspark.sql.functions import row_number, rank, dense_rank, col
from pyspark.sql.functions import regexp_replace, col
from pyspark.sql.window import Window
from pyspark.sql.functions import row_number
from pyspark.sql.functions import (
    trim,
    when,
    col,
    count,
    upper,
    to_date,
    current_date,
    current_timestamp,
    datediff,
    sum
)


# =====================================================
# CONFIG
# =====================================================

PROJECT_ID = "project-1928c187-e191-4e50-bee"

TEMP_BUCKET = "spalika_sales_data"


# =====================================================
# SPARK SESSION
# =====================================================

spark = (
    SparkSession.builder
    .appName("BigQueryIntegration")

    .config(
        "spark.jars.packages",
        ",".join([
            "com.google.cloud.spark:spark-3.5-bigquery:0.42.1",
            "com.google.cloud.bigdataoss:gcs-connector:hadoop3-2.2.21"
        ])
    )

    # IMPORTANT
    .config(
        "spark.hadoop.google.cloud.auth.service.account.enable",
        "false"
    )

    .config(
        "spark.hadoop.fs.gs.impl",
        "com.google.cloud.hadoop.fs.gcs.GoogleHadoopFileSystem"
    )

    .config(
        "spark.hadoop.fs.AbstractFileSystem.gs.impl",
        "com.google.cloud.hadoop.fs.gcs.GoogleHadoopFS"
    )

    .config(
        "temporaryGcsBucket",
        TEMP_BUCKET
    )

    .config(
        "parentProject",
        PROJECT_ID
    )

    .getOrCreate()
)

print("Spark Version:", spark.version)
# =====================================================
# READ BRONZE TABLE
# =====================================================

df = (
    spark.read.format("bigquery").load(
        "project-1928c187-e191-4e50-bee:bronze_sales_ds.erp_customer_extra_raw"
    )
)

erp_cust_df = df.withColumn(
    "CID",
    regexp_replace(col("CID"), "NASAW", "").cast("int")
)
windowSpec = Window.partitionBy("CID").orderBy("BDATE")

df_dedup = erp_cust_df.withColumn(
    "rn",
    row_number().over(windowSpec)
).filter("rn = 1").drop("rn")

clean_df = df_dedup.filter(
    col("BDATE").isNotNull() &
    (col("BDATE") <= current_date()) &
    ((datediff(current_date(), col("BDATE")) / 365) >= 18) &
    ((datediff(current_date(), col("BDATE")) / 365) <= 100)
)

clean_df = clean_df.withColumn(
    "BDATE",
    to_date(col("BDATE"), "yyyy-MM-dd")
)
clean_df = clean_df.withColumn(
    "ingestion_dt",
    current_timestamp()
)

clean_df = clean_df .withColumn(
    "GEN",
    when(
        upper(trim(col("GEN"))).isin("M", "MALE"),
        "Male"
    ).when(
        upper(trim(col("GEN"))).isin("F", "FEMALE"),
        "Female"
    ).when(
        trim(col("GEN")) == "",
        "n/a"
    ).otherwise("n/a")
)

# Convert Spark DataFrame to Pandas
pandas_df = clean_df.toPandas()
clean_df.printSchema()

# Create BigQuery client
client = bigquery.Client(project=PROJECT_ID)

# Target table
table_id = (
    "project-1928c187-e191-4e50-bee"
    ".silver_sales_ds.erp_customer_extra"
)

# Load job config
job_config = bigquery.LoadJobConfig(
    write_disposition="WRITE_APPEND"
)

# Load to BigQuery
job = client.load_table_from_dataframe(pandas_df,table_id,job_config=job_config )

# Wait for completion
job.result()

print("Silver table loaded successfully!")
